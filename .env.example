# AWS Configuration
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Cognito Configuration (from SAM outputs after deployment)
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Judge Configuration
JUDGE_NAME=codebreakercontest01
API_GATEWAY_LINK=wss://xxxxxxxxxx.execute-api.ap-southeast-1.amazonaws.com/production

# Database Mode
# Set to "true" to use DynamoDB, otherwise uses mock data
USE_DYNAMODB=false

# App Configuration
NODE_ENV=development
SESSION_SECRET=your-session-secret-min-32-chars-here

# Optional: Vite Configuration
VITE_API_URL=http://localhost:5173
